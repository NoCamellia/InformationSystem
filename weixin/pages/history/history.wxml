<view class="container">
  <view class="article-list" wx:if="{{articles.length > 0}}">
    <view 
      class="article-card"
      wx:for="{{articles}}" 
      wx:key="id"
      bindtap="onArticleTap"
      data-id="{{item.id}}"
    >
      <image class="article-image" src="{{item.coverImage}}" mode="aspectFill" />
      <view class="article-content">
        <view class="article-title">{{item.title}}</view>
        <view class="article-summary">{{item.summary}}</view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <view class="empty-icon">📖</view>
    <view class="empty-text">暂无浏览记录</view>
  </view>
</view>
