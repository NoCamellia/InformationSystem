.category-container {
  display: flex;
  height: 100vh;
}

.category-sidebar {
  width: 200rpx;
  background: #f5f7fa;
  height: 100vh;
}

.category-item {
  padding: 32rpx 24rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  position: relative;
  transition: all 0.3s;
}

.category-item.active {
  background: #fff;
  color: #6366f1;
  font-weight: bold;
}

.category-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 40rpx;
  background: #6366f1;
  border-radius: 0 6rpx 6rpx 0;
}

.article-container {
  flex: 1;
  height: 100vh;
  background: #fff;
}

.category-header {
  padding: 24rpx 20rpx 0;
  background: #fff;
}

.category-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #222;
  margin-bottom: 16rpx;
}

.child-category-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.child-category-tag {
  padding: 10rpx 18rpx;
  font-size: 24rpx;
  color: #6366f1;
  background: rgba(99, 102, 241, 0.08);
  border: 1rpx solid rgba(99, 102, 241, 0.18);
  border-radius: 999rpx;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin: 14rpx 0;
}

.card-tags-compact {
  margin: 10rpx 0 12rpx;
}

.card-tag {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #eef2ff;
  color: #5b5bd6;
  font-size: 20rpx;
  line-height: 1.2;
}

.article-list {
  padding: 20rpx;
}

.article-item {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.article-thumb {
  width: 200rpx;
  height: 150rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.article-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.article-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.article-summary {
  font-size: 26rpx;
  color: #999;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.article-meta {
  display: flex;
  gap: 24rpx;
  font-size: 24rpx;
  color: #999;
}
