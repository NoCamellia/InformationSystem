<view class="container">
  <!-- 用户信息 -->
  <view class="user-section">
    <view class="user-info" wx:if="{{hasUserInfo}}">
      <image class="avatar" src="{{userInfo.avatarUrl}}" />
      <view class="user-detail">
        <view class="nickname">{{userInfo.nickName}}</view>
        <view class="user-id">ID: {{userInfo.openid || '未登录'}}</view>
      </view>
    </view>
    <view class="user-info" wx:else>
      <image class="avatar" src="/images/default-avatar.png" />
      <view class="user-detail">
        <button class="login-btn" open-type="getUserProfile" bindgetuserinfo="onGetUserInfo">
          点击登录
        </button>
      </view>
    </view>
  </view>

  <!-- 统计数据 -->
  <view class="stats-section">
    <view class="stat-item" bindtap="onCollectTap">
      <view class="stat-value">{{stats.collectCount}}</view>
      <view class="stat-label">我的收藏</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item" bindtap="onHistoryTap">
      <view class="stat-value">{{stats.historyCount}}</view>
      <view class="stat-label">浏览历史</view>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="onCollectTap">
      <view class="menu-left">
        <text class="menu-icon">⭐</text>
        <text class="menu-text">我的收藏</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onHistoryTap">
      <view class="menu-left">
        <text class="menu-icon">📖</text>
        <text class="menu-text">浏览历史</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onAboutTap">
      <view class="menu-left">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-text">关于我们</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
