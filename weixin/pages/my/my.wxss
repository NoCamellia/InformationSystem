.user-section {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  padding: 60rpx 40rpx;
  margin-bottom: 20rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.user-detail {
  flex: 1;
  color: #fff;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.user-id {
  font-size: 26rpx;
  opacity: 0.8;
}

.login-btn {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 40rpx;
  padding: 16rpx 48rpx;
  font-size: 28rpx;
}

.login-btn::after {
  border: none;
}

.stats-section {
  display: flex;
  background: #fff;
  padding: 40rpx;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #6366f1;
  margin-bottom: 12rpx;
}

.stat-label {
  font-size: 26rpx;
  color: #999;
}

.stat-divider {
  width: 2rpx;
  background: #f0f0f0;
}

.menu-section {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 40rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.menu-icon {
  font-size: 40rpx;
}

.menu-text {
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  font-size: 48rpx;
  color: #ccc;
}
