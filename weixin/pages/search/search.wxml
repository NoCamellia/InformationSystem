<view class="container">
  <view class="search-box">
    <input 
      class="search-input" 
      placeholder="搜索文章" 
      value="{{keyword}}"
      bindinput="onInputChange"
      confirm-type="search"
      bindconfirm="onSearch"
    />
    <button class="search-btn" bindtap="onSearch">搜索</button>
  </view>

  <view class="result-container" wx:if="{{searched}}">
    <view class="article-list" wx:if="{{articles.length > 0}}">
      <view 
        class="article-card"
        wx:for="{{articles}}" 
        wx:key="id"
        bindtap="onArticleTap"
        data-id="{{item.id}}"
      >
        <image class="article-image" src="{{item.coverImage}}" mode="aspectFill" />
        <view class="article-content">
          <view class="article-title">{{item.title}}</view>
          <view class="article-summary">{{item.summary}}</view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{!loading && articles.length === 0}}">
      <view class="empty-icon">🔍</view>
      <view class="empty-text">未找到相关文章</view>
    </view>

    <view class="loading-more" wx:if="{{loading}}">搜索中...</view>
  </view>
</view>
