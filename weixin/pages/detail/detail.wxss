.article-header {
  background: #fff;
  padding: 40rpx;
  margin-bottom: 20rpx;
}

.article-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.article-info {
  display: flex;
  align-items: center;
  gap: 32rpx;
  margin-bottom: 24rpx;
  font-size: 26rpx;
  color: #666;
}

.article-stats {
  display: flex;
  align-items: center;
  gap: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
  font-size: 26rpx;
  color: #999;
}

.cover-image {
  width: 100%;
  display: block;
  margin-bottom: 20rpx;
}

.article-body {
  background: #fff;
  padding: 40rpx;
  margin-bottom: 120rpx;
  font-size: 32rpx;
  line-height: 1.8;
  color: #333;
}

.article-body rich-text {
  word-break: break-all;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: #fff;
  padding: 20rpx;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  background: transparent;
  border: none;
  padding: 0;
  line-height: 1;
}

.share-btn::after {
  border: none;
}

.action-icon {
  font-size: 48rpx;
  transition: all 0.3s;
}

.action-icon.active {
  transform: scale(1.2);
}

.action-text {
  font-size: 24rpx;
  color: #666;
}

.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}
